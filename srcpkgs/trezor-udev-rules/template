do_extract() {
	# Single file, not an archive - copy to work directory
	cp "${XBPS_SRCDISTDIR}"/${pkgname}-${version}/51-trezor.rules "${wrksrc}"/
}

do_install() {
	vinstall 51-trezor.rules 644 usr/lib/udev/rules.d
}
