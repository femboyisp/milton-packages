post_extract() {
	mkdir -p external/quirc monero
	vsrcextract -C external/quirc "quirc-${_quirc_commit}.tar.gz"
	vsrcextract -C monero "monero-core-${_monero_commit}.tar.gz"
	mkdir -p monero/external/randomx monero/external/rapidjson \
		monero/external/supercop monero/external/trezor-common
	vsrcextract -C monero/external/randomx "randomx-${_randomx_commit}.tar.gz"
	vsrcextract -C monero/external/rapidjson "rapidjson-${_rapidjson_commit}.tar.gz"
	vsrcextract -C monero/external/supercop "supercop-${_supercop_commit}.tar.gz"
	vsrcextract -C monero/external/trezor-common "trezor-common-${_trezorcommon_commit}.tar.gz"
}

post_patch() {
	vsed -i 's/-DCMAKE_CXX_STANDARD=11/-DCMAKE_CXX_STANDARD=17/' monero/cmake/CheckTrezor.cmake
	vsed -i 's/set(CMAKE_CXX_STANDARD 14)/set(CMAKE_CXX_STANDARD 17)/' monero/CMakeLists.txt
}

post_install() {
	vlicense LICENSE

	# monero-gui vendors and builds its own copy of the monero core as an
	# internal subdirectory (see post_extract above). monero's own
	# CMakeLists.txt unconditionally installs its own daemon/CLI binaries
	# and a devel header alongside monero-wallet-gui; those are identical
	# in path to what the separate 'monero' package ships, and would
	# conflict with it. This package's interface is only
	# /usr/bin/monero-wallet-gui, so prune everything else the vendored
	# core's install rules add, to prevent any conflict with 'monero'.
	rm -f ${DESTDIR}/usr/bin/monero-blockchain-* \
		${DESTDIR}/usr/bin/monero-gen-ssl-cert \
		${DESTDIR}/usr/bin/monero-gen-trusted-multisig \
		${DESTDIR}/usr/bin/monero-wallet-cli \
		${DESTDIR}/usr/bin/monero-wallet-rpc \
		${DESTDIR}/usr/bin/monerod
	rm -rf ${DESTDIR}/usr/include/wallet
	rm -f ${DESTDIR}/usr/lib/libeasylogging.a \
		${DESTDIR}/usr/lib/libepee.a \
		${DESTDIR}/usr/lib/libepee_readline.a \
		${DESTDIR}/usr/lib/liblmdb.a

	vinstall share/org.getmonero.Monero.desktop 644 usr/share/applications
	for size in 16 24 32 48 64 96 128 256; do
		vinstall images/appicons/${size}x${size}.png 644 \
			usr/share/icons/hicolor/${size}x${size}/apps org.getmonero.Monero.png
	done
}
